{
  "name": "chess-summon",
  "version": "0.1.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron": "electron .",
    "dist": "vite build && electron-builder --win --x64",
    "build:html": "cross-env BUILD_MODE=singlefile vite build"
  },
  "build": {
    "appId": "com.chesssummon.game",
    "productName": "Chess Summon",
    "copyright": "Copyright © 2026",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "ChessSummon_v0.1.1_portable.exe"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0",
    "jimp": "^0.22.12",
    "phaser": "^3.87.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.0.0"
  }
}
